# Example environment variables — DO NOT commit real secrets here.
# Copy this to `.env.local` and fill with real values for your environment.

APP_ENV=dev
APP_SECRET=ReplaceWithYourAppSecret
API_TOKEN=REPLACE_ME_WITH_API_TOKEN
DATABASE_URL="mysql://symfony:password@127.0.0.1:3306/ledger_flow?serverVersion=8.0&charset=utf8mb4"
REDIS_URL=redis://127.0.0.1:6379
APP_SHARE_DIR=var/share

